a = 2; b = 1; a2 = a*a; b2 = b*b;
afa = (0:0.1:2*pi)';
r = sqrt(a2*b2./(b2*sin(afa).^2+a2*cos(afa).^2));
afa = (-pi/4:0.1:7*pi/4)';

afa1 = -pi/4:0.1:pi/4; afa2 = afa1+2*pi/4; afa3 = afa2*2*pi/4; afa4 = afa3+2*pi/4;
r1 = 1./cos(afa1);
afa = [afa1, afa2, afa3, afa4]'; r = [r1,r2,r3,r4]'

for NN=1:10
    [a0, anbn, w1] = fsfitting([afa,r], NN);
    xx = a0; tt = afa;
    for n=1:NN
        wt = n*w1*tt;
        xx = xx + anbn(n,1)*cos(wt) + anbn(n,2)*sin(wt);
    end
    % plot(afa,r, tt,xx, 'r'); grid on
    L = 1.1*max(a,b);
    plot(r.*cos(afa),r.*sin(afa), xx.*cos(afa),xx.*sin(afa), 'r'); xlim([-L,L]); ylim([-L,L]); grid on
    pause(1);
end